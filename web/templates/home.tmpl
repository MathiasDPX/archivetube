{{define "title"}}ArchiveTube{{end}}
{{define "content"}}
<div class="page-shell">
    {{if .Videos}}
    <div class="video-grid" data-infinite-grid data-infinite-api="/api/videos?q={{.Query}}" data-infinite-page="{{.Page}}" data-infinite-total="{{.Total}}" data-infinite-perpage="{{.PerPage}}">
        {{range .Videos}}
        <div class="video-card">
            <a href="/videos/{{.YoutubeVideoID}}" class="thumb-link">
                <div class="thumb">
                    {{if .ThumbnailRelPath}}
                    <img src="/data/{{webPath .ThumbnailRelPath}}" alt="" loading="lazy">
                    {{end}}
                    <span class="badge-duration">{{fmtDuration .DurationSeconds}}</span>
                </div>
            </a>
            <div class="card-body">
                <a href="/videos/{{.YoutubeVideoID}}" class="card-title">{{.Title}}</a>
                <a href="/creators/{{.ChannelYoutubeID}}" class="card-channel">{{.ChannelName}}</a>
                <span class="card-meta">Archived {{fmtDate .ArchivedAt}}</span>
            </div>
        </div>
        {{end}}
    </div>
    {{else}}
    <div class="empty">
        <p>No videos found.</p>
        <a href="/archive" class="link-subtle">Archive your first video →</a>
    </div>
    {{end}}
</div>
{{end}}
{{define "scripts"}}
<script src="/static/js/infinite-scroll.js"></script>
{{end}}
