{{define "title"}}{{.Channel.Name}} - ArchiveTube{{end}}
{{define "content"}}
<div class="page-shell">
    {{if .Channel.BannerPath}}
    <div class="creator-banner">
        <img src="/data/{{webPath .Channel.BannerPath}}" alt="">
    </div>
    {{end}}
    <div class="creator-header">
        <div class="creator-profile">
            {{if .Channel.ThumbnailPath}}<img src="/data/{{webPath .Channel.ThumbnailPath}}" alt="" class="avatar avatar-lg">{{end}}
            <div>
                <div style="display:flex;align-items:center;gap:8px;">
                    <h1 class="page-heading" style="margin:0;">{{.Channel.Name}}</h1>
                    {{if or (not authEnabled) (loggedIn)}}
                    <div class="dropdown">
                        <button type="button" class="threedots-btn dropdown-toggle" aria-label="Options">
                            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/></svg>
                        </button>
                        <div class="dropdown-menu">
                            <form method="post" action="/creators/{{.Channel.YoutubeChannelID}}/refresh">
                                <button type="submit" class="dropdown-item">
                                    <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M17.65 6.35A7.958 7.958 0 0012 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0112 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/></svg>
                                    Refresh metadata
                                </button>
                            </form>
                            <a href="/archive?url=https://www.youtube.com/channel/{{.Channel.YoutubeChannelID}}" class="dropdown-item">
                                <svg width="16" height="16" viewBox="0 0 512 512" fill="none" stroke="currentColor" stroke-width="40" stroke-linecap="round"><path d="M401.35 170.444V273.111c0 64.53 0 96.796-20.034 116.842C361.283 410 329.038 410 264.55 410h-17.1c-64.488 0-96.732 0-116.766-20.047-20.034-20.046-20.034-52.312-20.034-116.842V170.444M85 136.222c0-16.132 0-24.198 5.008-29.21C95.017 102 103.078 102 119.2 102h273.6c16.122 0 24.183 0 29.191 5.012C427 112.024 427 120.09 427 136.222c0 16.133 0 24.199-5.009 29.211-5.008 5.011-13.069 5.011-29.191 5.011H119.2c-16.122 0-24.183 0-29.192-5.011C85 160.421 85 152.355 85 136.222Z"/></svg>
                                Rearchive
                            </a>
                            <form method="post" action="/creators/{{.Channel.YoutubeChannelID}}/delete" onsubmit="return confirm('Are you sure you want to delete the channel avatar and banner?')">
                                <button type="submit" class="dropdown-item dropdown-item-danger">
                                    <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
                                    Delete
                                </button>
                            </form>
                            <span class="dropdown-item" style="cursor: default;">{{.Total}} video{{if ne .Total 1}}s{{end}} archived</span>
                        </div>
                    </div>
                    {{end}}
                </div>
                {{if .Channel.Handle}}<p class="creator-handle">{{.Channel.Handle}}</p>{{end}}
            </div>
        </div>
    </div>

    {{if .Videos}}
    <div class="video-grid" data-infinite-grid data-infinite-api="/api/creators/{{.Channel.YoutubeChannelID}}/videos" data-infinite-page="{{.Page}}" data-infinite-total="{{.Total}}" data-infinite-perpage="{{.PerPage}}" data-infinite-show-channel="false">
        {{range .Videos}}
        <div class="video-card">
            <a href="/videos/{{.YoutubeVideoID}}" class="thumb-link">
                <div class="thumb">
                    {{if .ThumbnailRelPath}}
                    <img src="/data/{{webPath .ThumbnailRelPath}}" alt="" loading="lazy">
                    {{end}}
                    <span class="badge-duration">{{fmtDuration .DurationSeconds}}</span>
                </div>
            </a>
            <div class="card-body">
                <a href="/videos/{{.YoutubeVideoID}}" class="card-title">{{.Title}}</a>
                <span class="card-meta">Archived {{fmtDate .ArchivedAt}}</span>
            </div>
        </div>
        {{end}}
    </div>
    {{else}}
    <div class="empty"><p>No archived videos from this creator yet.</p></div>
    {{end}}
</div>
{{end}}
{{define "scripts"}}
<script src="/static/js/infinite-scroll.js"></script>
<script>
document.querySelectorAll('.dropdown-toggle').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
        e.stopPropagation();
        btn.closest('.dropdown').classList.toggle('open');
    });
});
document.addEventListener('click', function() {
    document.querySelectorAll('.dropdown.open').forEach(function(d) {
        d.classList.remove('open');
    });
});
</script>
{{end}}
