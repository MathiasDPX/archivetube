{{define "title"}}{{.Video.Title}} - ArchiveTube{{end}}

{{ define "opengraph" }}
<meta property="og:image" content="/data/{{ webPath .Video.ThumbnailRelPath }}">
<meta property="og:title" content="{{ .Video.Title }} - ArchiveTube">
<meta property="og:description" content="{{ ogDesc .Video.Description }}" />
<meta name="twitter:card" content="summary_large_image">
{{ end }}

{{define "content"}}
<div class="watch-page">
    <div class="player-wrap">
        <video id="video-player" controls preload="metadata" data-channel-id="{{.Channel.YoutubeChannelID}}" data-video-id="{{.Video.YoutubeVideoID}}">
            <source src="/data/{{webPath .Video.VideoRelPath}}" type="video/mp4">
            {{range .Subtitles}}
            <track kind="subtitles" src="/data/{{webPath .RelPath}}" srclang="{{.LanguageCode}}" label="{{if .LanguageName}}{{.LanguageName}}{{else}}{{.LanguageCode}}{{end}}">
            {{end}}
        </video>
    </div>

    <div class="watch-below">
        <h1 class="watch-title" id="video-title">{{.Video.Title}}</h1>

        <div class="watch-bar">
            <a href="/creators/{{.Channel.YoutubeChannelID}}" class="watch-channel">
                {{if .Channel.ThumbnailPath}}<img src="/data/{{webPath .Channel.ThumbnailPath}}" alt="" id="channel-avatar" class="avatar avatar-channel">{{end}}
                <span id="channel-name">{{.Channel.Name}}</span>
            </a>
            <div class="watch-actions">
                <a href="/download/{{.Video.YoutubeVideoID}}" target="_blank" class="action-btn">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M5 20h14v-2H5v2zm7-18l-5.5 8h3.5v6h4v-6h3.5L12 2z"/></svg>
                    Download
                </a>
                {{if or (not authEnabled) (loggedIn)}}
                <form method="post" action="/videos/{{.Video.YoutubeVideoID}}/delete" onsubmit="return confirm('Are you sure you want to delete this video?')">
                    <button type="submit" class="action-btn" style="color:#f44;">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
                        Delete
                    </button>
                </form>
                {{end}}
                {{if .Video.WebpageURL}}
                <a href="{{.Video.WebpageURL}}" target="_blank" rel="noopener" class="action-btn">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M19 19H5V5h7V3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
                    Original
                </a>
                {{end}}
            </div>
        </div>

        <div class="watch-info-box">
            <div class="watch-stats">
                {{if .Video.PublishedAt}}<span>{{fmtDatePtr .Video.PublishedAt}}</span>{{end}}
                <span>{{fmtDuration .Video.DurationSeconds}}</span>
                {{if .Video.FileSizeBytes}}<span>{{fmtSize .Video.FileSizeBytes}}</span>{{end}}
                <span>Archived {{fmtDate .Video.ArchivedAt}}</span>
            </div>
            <div class="watch-description">{{linkify .Video.Description}}</div>
        </div>

        {{if .Chapters}}
        <div class="watch-chapters">
            <h2 class="section-label">Chapters</h2>
            <div class="chapter-list">
                {{range .Chapters}}
                <div class="chapter-item" data-time="{{.StartSeconds}}" data-end="{{.EndSeconds}}">
                    <span class="ch-time">{{fmtDuration (ftoi .StartSeconds)}}</span>
                    <span class="ch-title">{{.Title}}</span>
                </div>
                {{end}}
            </div>
        </div>
        {{end}}
    </div>
</div>
{{end}}
{{define "scripts"}}<script src="/static/js/player.js"></script>{{end}}
