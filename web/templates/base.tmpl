{{define "base"}}<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{block "title" .}}ArchiveTube{{end}}</title>
    <link rel="icon" type="image/png" href="/static/favicon.svg">
    <link rel="stylesheet" href="/static/css/main.css">
</head>
<body>
    <header class="topbar">
        <div class="topbar-inner">
            <a href="/" class="logo"><img src="/static/favicon.svg"> <span class="logo-text">ArchiveTube</span></a>
            <form class="topbar-search" method="get" action="/">
                <div class="search-box">
                    <input type="text" name="q" placeholder="Search" class="search-input">
                    <button type="submit" class="search-btn" aria-label="Search">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" height="24" viewBox="0 0 24 24" width="24" focusable="false" aria-hidden="true" style="pointer-events: none; display: inherit; width: 100%; height: 100%;"><path d="M11 2a9 9 0 105.641 16.01.966.966 0 00.152.197l3.5 3.5a1 1 0 101.414-1.414l-3.5-3.5a1 1 0 00-.197-.153A8.96 8.96 0 0020 11a9 9 0 00-9-9Zm0 2a7 7 0 110 14 7 7 0 010-14Z"></path></svg>
                    </button>
                </div>
            </form>
            <nav class="nav-links">
                <a href="/">Home</a>
                <a href="/creators">Creators</a>
                {{if or (not authEnabled) (loggedIn)}}
                <a href="/archive">Archive</a>
                {{else}}
                <a href="/login">Login</a>
                {{end}}
            </nav>
        </div>
    </header>
    <main>
        {{block "content" .}}{{end}}
    </main>
    {{block "scripts" .}}{{end}}
</body>
</html>{{end}}
