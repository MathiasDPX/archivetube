{{define "base"}}<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{block "title" .}}ArchiveTube{{end}}</title>
    <link rel="stylesheet" href="/static/css/main.css">
</head>
<body>
    <header class="topbar">
        <div class="topbar-inner">
            <a href="/" class="logo">📼 <span class="logo-text">ArchiveTube</span></a>
            <form class="topbar-search" method="get" action="/">
                <div class="search-box">
                    <input type="text" name="q" placeholder="Search" class="search-input">
                    <button type="submit" class="search-btn" aria-label="Search">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
                    </button>
                </div>
            </form>
            <nav class="nav-links">
                <a href="/">Home</a>
                <a href="/creators">Creators</a>
                <a href="/archive">Archive</a>
            </nav>
        </div>
    </header>
    <main>
        {{block "content" .}}{{end}}
    </main>
    {{block "scripts" .}}{{end}}
</body>
</html>{{end}}
