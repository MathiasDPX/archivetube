{{define "title"}}Archive - ArchiveTube{{end}}
{{define "content"}}
<div class="page-narrow">
    <h1 class="page-heading">Archive</h1>
    <p class="page-sub">Paste a YouTube URL below — a single video, a playlist, or a channel. For playlists and channels, you can pick which videos to download.</p>

    {{if .Error}}
    <div class="alert alert-error">{{.Error}}</div>
    {{end}}

    <form method="post" action="/archive" class="archive-form" id="archive-form">
        <label for="url" class="form-label">URL</label>
        <div class="archive-url-row">
            <input type="url" id="url" name="url" placeholder="https://www.youtube.com/watch?v=..." class="form-input" required autofocus {{if .PrefilledURL}}value="{{.PrefilledURL}}"{{end}}>
            <select name="quality" id="quality" class="form-select">
                <option value="best">Best</option>
                <option value="2160">2160p (4K)</option>
                <option value="1440">1440p</option>
                <option value="1080" selected>1080p</option>
                <option value="720">720p</option>
                <option value="480">480p</option>
                <option value="360">360p</option>
            </select>
            <button type="submit" class="form-submit" id="smart-btn">
                <span id="smart-btn-label">Archive</span>
            </button>
        </div>
    </form>

    <div id="playlist-picker" class="playlist-picker" style="display:none;">
        <div class="playlist-picker-header">
            <h2 class="section-label" id="playlist-picker-title">Videos</h2>
            <div class="playlist-picker-actions">
                <button type="button" class="queue-clear-btn" id="playlist-select-all">Select all</button>
                <button type="button" class="queue-clear-btn" id="playlist-deselect-all">Deselect all</button>
                <button type="button" class="form-submit form-submit-sm" id="playlist-archive-btn">Archive selected</button>
            </div>
        </div>
        <div id="playlist-list" class="playlist-list"></div>
        <div id="playlist-loading" class="playlist-loading" style="display:none;">
            <span class="queue-status-dot" style="background:var(--blue);animation:pulse 1.2s infinite;"></span>
            Fetching videos…
        </div>
        <div id="playlist-error" class="alert alert-error" style="display:none;"></div>
    </div>

    <div class="queue-section">
        <div class="queue-header">
            <h2 class="section-label">Queue</h2>
            <form method="post" action="/archive/clear" id="clear-form" style="display:none;">
                <button type="submit" class="queue-clear-btn">Clear finished</button>
            </form>
        </div>
        <div id="queue-list" class="queue-list">
            {{if .Jobs}}
            {{range .Jobs}}
            <div class="queue-item queue-{{.Status}}">
                <span class="queue-status-dot"></span>
                <span class="queue-url">{{.URL}}</span>
                <span class="queue-status-label">{{.Status}}</span>
                {{if .Error}}<span class="queue-error">{{.Error}}</span>{{end}}
            </div>
            {{end}}
            {{else}}
            <p class="queue-empty">No jobs in the queue.</p>
            {{end}}
        </div>
    </div>
</div>
{{end}}
{{define "scripts"}}
<script src="/static/js/queue.js"></script>
<script src="/static/js/playlist.js"></script>
{{end}}
